# Trajectory Coaching — environment.
# Copy to .env.local and fill in. .env.local is gitignored; this file is committed.

# ---------------------------------------------------------------------------
# Neon Postgres
#
# TWO different URLs, on purpose:
#   DATABASE_URL          POOLED   (host contains "-pooler") — used by the app
#   DATABASE_URL_UNPOOLED DIRECT   (no "-pooler")            — used by drizzle-kit
#
# Migrations must NOT go through PgBouncer: DDL in transaction-pooling mode is a
# known source of weird failures.
# ---------------------------------------------------------------------------
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# ---------------------------------------------------------------------------
# Clerk
#
# Phase 0 uses DEV keys (pk_test_/sk_test_) even on Vercel. A Clerk production
# instance requires DNS records on a real domain, which is blocked on spec §14.5
# (keep trajectorycoaches.com vs. stage on a subdomain). Dev instances work on any
# origin.
#
# ⚠️ Also required, with NO code equivalent — Clerk Dashboard → Sessions →
# Customize session token → Claims editor:
#     { "metadata": "{{user.public_metadata}}" }
# Without it, sessionClaims.metadata.role is silently undefined and every role
# check fails.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Clerk Dashboard → Webhooks → endpoint /api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SIGNING_SECRET=""

# Use the FALLBACK_/FORCE_ variants — NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL and
# AFTER_SIGN_UP_URL are deprecated.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/onboarding/role"

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional. Required to reach /api/health in production (x-health-token header).
HEALTH_CHECK_TOKEN=""

# ---------------------------------------------------------------------------
# PHASE 1 — not used yet. Listed so the names are settled and nobody invents
# different ones later.
# ---------------------------------------------------------------------------
# RESEND_API_KEY=""
# CALENDLY_API_TOKEN=""
# CALENDLY_WEBHOOK_SIGNING_KEY=""
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
